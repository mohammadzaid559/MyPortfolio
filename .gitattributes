# Auto-detect text files and normalize to LF in repo
* text=auto

# Force LF for source files
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts (if any)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files (no conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary